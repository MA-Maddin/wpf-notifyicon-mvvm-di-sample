<Application x:Class="NotifyIconMvvmDISample.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NotifyIconMvvmDISample"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <tb:TaskbarIcon x:Key="NotifyIcon"
                        IconSource="/Assets/app.ico"
                        ToolTipText="My App"
                        NoLeftClickDelay="True"
                        LeftClickCommand="{Binding ShowCommand}">
            
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show" Command="{Binding ShowCommand}" />
                    <MenuItem Header="Exit" Command="{Binding ExitCommand}" />
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
            
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
