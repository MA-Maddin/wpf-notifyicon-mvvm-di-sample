<UserControl x:Class="NotifyIconMvvmDISample.Views.PopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NotifyIconMvvmDISample.Views"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="200">
    <Border Padding="12" Background="White" BorderBrush="#DDD" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="{Binding Title}" d:Text="Title" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Message}" d:Text="Message" Margin="0,8,0,0" />
            <Button Content="Close"
                    Margin="0,12,0,0"
                    Command="{Binding CloseCommand}" />
        </StackPanel>
    </Border>
</UserControl>
